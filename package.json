{
  "name": "boilersub-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "graphify:build": "npm exec --yes --package graphify-ts -- graphify build ."
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@google/stitch-sdk": "^0.1.0",
    "@supabase/supabase-js": "^2.55.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "supabase": "^2.89.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
